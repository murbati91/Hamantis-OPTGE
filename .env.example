# Copy to .env and fill in. Only VITE_-prefixed vars reach the client bundle.

# Clerk auth (REQUIRED) — Clerk → Configure → API Keys.
# Development = pk_test_… (works on any domain, no DNS). Production = pk_live_…
# (needs the Clerk Domains DNS records added to your domain first).
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# Supabase opt-in cloud sync (optional) — Project → Settings → API.
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJxxxxxxxx...

# NEVER put a Clerk SECRET key or a Supabase SERVICE_ROLE key in a VITE_ var —
# they would be bundled into the public client. Those belong server-side only.
